rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: messages
    // Fields:
    //   - id: string (required)
    //   - role: string (required, enum: user, assistant)
    //   - content: string (required, max 5000 chars)
    //   - timestamp: timestamp (required)
    //   - userId: string (required, must match auth.uid)
    //
    // Collection: users
    // Fields:
    //   - displayName: string (required)
    //   - studyMethod: string (required, enum: Pomodoro, Active Recall, Spaced Repetition, Feynman Technique)
    //   - notificationsEnabled: boolean (required)
    //   - dailyGoal: number (optional)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'role', 'content', 'timestamp', 'userId']) &&
             data.id is string &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() <= 5000 &&
             data.timestamp is timestamp &&
             data.userId == request.auth.uid;
    }

    function isValidStats(stats) {
      return stats.keys().hasAll(['streak', 'weeklyHours', 'todayHours', 'level', 'xp', 'focusScore', 'sessionsCompleted', 'mostStudiedSubject', 'lastActiveDate']) &&
             stats.streak is int && stats.streak >= 0 &&
             stats.weeklyHours is number && stats.weeklyHours >= 0 &&
             stats.todayHours is number && stats.todayHours >= 0 &&
             stats.level is int && stats.level >= 1 &&
             stats.xp is int && stats.xp >= 0 &&
             stats.focusScore is int && stats.focusScore >= 0 && stats.focusScore <= 100 &&
             stats.sessionsCompleted is int && stats.sessionsCompleted >= 0 &&
             stats.mostStudiedSubject is string &&
             stats.lastActiveDate is string &&
             (!('subjectStats' in stats) || stats.subjectStats is map);
    }

    function isValidUserSettings(data) {
      return data.keys().hasAll(['displayName', 'studyMethod', 'notificationsEnabled', 'updatedAt', 'subjects']) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.studyMethod in ['Pomodoro', 'Active Recall', 'Spaced Repetition', 'Feynman Technique'] &&
             data.notificationsEnabled is bool &&
             data.updatedAt is timestamp &&
             data.subjects is list && data.subjects.size() > 0 &&
             (!('dailyGoal' in data) || (data.dailyGoal is int && data.dailyGoal >= 1 && data.dailyGoal <= 24)) &&
             (!('reminderTime' in data) || data.reminderTime is string) &&
             (!('blockedApps' in data) || (data.blockedApps is list && data.blockedApps.size() <= 20)) &&
             (!('allowedTools' in data) || (data.allowedTools is list && data.allowedTools.size() <= 20)) &&
             (!('stats' in data) || isValidStats(data.stats));
    }

    function isValidStudyFile(data) {
      return data.keys().hasAll(['name', 'type', 'content', 'uploadedAt', 'userId']) &&
             data.name is string && data.name.size() > 0 &&
             data.type is string &&
             data.content is string && data.content.size() <= 600000 &&
             data.uploadedAt is timestamp &&
             data.userId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update: if false; // Messages are immutable
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserSettings(request.resource.data);
      allow delete: if false;
    }

    match /studyFiles/{fileId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidStudyFile(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
